# Copie este arquivo para .env.local e preencha os valores.
# No Vercel, configure os mesmos em Project Settings → Environment Variables.

# URL final do site (usada para montar os links de compartilhamento / Open Graph).
SITE_URL=https://sorteselada.cenlo.pt

# Senha que você digita para entrar na área restrita /sortear.
SORTEIO_SENHA=troque-esta-senha

# Texto aleatório longo — o valor do cookie de sessão. Sem ele, /sortear fica bloqueado.
SORTEIO_SESSION_SECRET=troque-por-um-texto-aleatorio-longo

# Onde as rodadas publicadas ficam guardadas (Vercel Blob). No Vercel: crie um
# Blob store (Storage → Create → Blob) e ele injeta esta variável sozinho.
# Sem ela, publicar não funciona e a galeria fica vazia.
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_...
